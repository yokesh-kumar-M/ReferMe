{
  "manifest_version": 3,
  "name": "ReferMe Agent",
  "version": "1.0.0",
  "description": "Personal AI Agent to detect job applications, extract context, and generate personalized referrals.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Open ReferMe Agent",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "management"
  ],
  "background": {
    "service_worker": "hot-reload.js"
  },
  "host_permissions": [
    "*://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["index.html", "*"],
      "matches": ["*://*/*"]
    }
  ]
}
